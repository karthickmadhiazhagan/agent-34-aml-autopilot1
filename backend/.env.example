# ============================================================
# AML Autopilot – Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git.
# ============================================================

# --- Anthropic Claude API ---
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Google Gemini API (free tier available) ---
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- AI Mode ---
# Set to "true" to use pre-built mock responses (no API credits needed).
# Set to "false" or remove to use the real Claude API.
MOCK_AI=false

# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password

# --- Rails ---
RAILS_ENV=development
SECRET_KEY_BASE=run_rails_secret_to_generate_this
