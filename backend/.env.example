# ============================================================
# AML Autopilot – Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git.
# ============================================================

# --- Google Gemini API (free tier — recommended) ---
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Anthropic Claude API (optional — paid) ---
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key-here
# CLAUDE_MODEL=claude-haiku-4-5-20251001   ← cheapest (~$0.006/investigation)
# CLAUDE_MODEL=claude-sonnet-4-6           ← better quality (~$0.017/investigation)

# --- AI Mode ---
#
#   MOCK_AI=true  + SMART_AI=false  → 0 API calls  (full mock — for testing)
#   MOCK_AI=false + SMART_AI=true   → 1 API call   (Agent 4 only — recommended for demo)
#   MOCK_AI=false + SMART_AI=false  → 5 API calls  (all agents — maximum quality)
#
# NOTE: MOCK_AI=true overrides SMART_AI.
MOCK_AI=false
SMART_AI=true

# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password

# --- Rails ---
RAILS_ENV=development
SECRET_KEY_BASE=run_rails_secret_to_generate_this
